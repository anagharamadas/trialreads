# ─────────────────────────────────────────────────────────────
# TrialReads backend environment template.
# Copy to backend/.env and fill in real values. backend/.env is gitignored.
# NEVER commit real keys. The service-role key + OpenAI key are BACKEND ONLY.
# ─────────────────────────────────────────────────────────────

# ── OpenAI ──
OPENAI_API_KEY=sk-...

# ── Supabase: API (Project Settings → API) ──
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=ey...            # public/anon key (safe-ish; also given to frontend)
SUPABASE_SERVICE_ROLE_KEY=ey...    # SECRET — backend only, bypasses RLS, never to frontend

# ── Supabase: JWT verification (Project Settings → API → JWT Settings) ──
# Used by the backend to validate the token the frontend sends.
# We finalize the exact method in Milestone 2 per Supabase's current docs
# (legacy HS256 shared secret vs. asymmetric JWKS). Save the secret now.
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Supabase: Postgres connection (Project Settings → Database → Connection string → URI) ──
# Replace [YOUR-PASSWORD] with your DB password. We confirm pooler vs direct in M2.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# ── Google Books API (book covers, grounding) ──
GOOGLE_BOOKS_API_KEY=AIza...

# ── Hardcover.app (book ratings; hardcover.app → Settings → Hardcover API) ──
# Empty = rating lookups disabled (Google Books' sparse ratings remain the fallback).
HARDCOVER_API_KEY=

# ── Server ──
DEBUG=False
PORT=8000
HOST=0.0.0.0

# ── CORS (frontend origin; locked to your Vercel domain in production) ──
CORS_ORIGINS=["http://localhost:3000"]
# Allow any localhost port (dev). Set to false in production (Render) so only
# CORS_ORIGINS (your Vercel domain) is permitted.
CORS_ALLOW_LOCALHOST=true

# ── Logging ──
LOG_LEVEL=INFO

# ── Observability (Phase 3) — all optional; unset = telemetry off ──
# Local trace lab (M1): run Jaeger (docker-compose.jaeger.yml) and uncomment
# ALL THREE (Jaeger is traces-only — metric/log exports would 404 against it):
#  OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
#  OTEL_LOGS_EXPORT=false
#  OTEL_METRICS_EXPORT=false
# Grafana Cloud (M2+): paste the values its OTLP setup flow generates:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<zone>.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 of instanceID:token>
# Resource attribute deployment.environment (local | production):
DEPLOYMENT_ENVIRONMENT=local

# ── Langfuse LLM observability (M5) — optional; unset = disabled ──
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_TRACING_ENVIRONMENT=local
