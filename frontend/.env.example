# ─────────────────────────────────────────────────────────────
# TrialReads frontend env template. Copy to .env.local and fill in.
# Only NEXT_PUBLIC_* vars reach the browser — NEVER put secrets here
# (no service-role key, no OpenAI key). The anon/publishable key is fine.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Backend API base URL (local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
