# ─── Secrets (NEVER commit) ───────────────────────────────
# Real env files are ignored; *.example templates are committed (see !rules below).
.env
.env.local
.env.*.local
*.env
# but DO keep the templates that document required variables:
!.env.example
!**/.env.example

# ─── Python / backend ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
backend/trialreads.db

# ─── Node / Next.js / frontend ────────────────────────────
node_modules/
.next/
out/
build/
.vercel/

# ─── IDE / OS ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
